---
const links = [
  { href: '#making', label: 'Making' },
  { href: '#now', label: 'Now' },
  { href: '#journey', label: 'Journey' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="header" id="site-header">
  <div class="header__inner wrap">
    <a href="/" class="header__brand" aria-label="Home">
      <img src={`${import.meta.env.BASE_URL}mayi-mark.svg`} alt="" width="32" height="32" aria-hidden="true" />
      <span class="header__name">Mayibongwe<span class="header__name-dim"> Sibanda</span></span>
    </a>
    <nav class="header__nav" aria-label="Primary">
      {links.map(({ href, label }) => (
        <a href={href} class="header__link">{label}</a>
      ))}
      <a href="https://www.linkedin.com/in/mayibongwe" rel="noopener noreferrer" target="_blank" class="header__link header__link--accent">
        LinkedIn
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding-block: 1rem;
    background: transparent;
    transition: background var(--transition), box-shadow var(--transition), padding var(--transition);
  }

  .header.is-scrolled {
    background: rgba(9, 9, 11, 0.85);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    box-shadow: 0 1px 0 var(--border);
    padding-block: 0.65rem;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--text);
    transition: opacity var(--transition);
  }

  .header__brand:hover { opacity: 0.8; color: var(--text); }

  .header__name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .header__name-dim {
    color: var(--text-muted);
    font-weight: 400;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.75rem;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    border-radius: 100px;
    transition: color var(--transition), background var(--transition);
  }

  .header__link:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
  }

  .header__link--accent {
    color: var(--accent);
  }

  .header__link--accent:hover {
    color: var(--accent-light);
    background: var(--accent-dim);
  }

  @media (max-width: 640px) {
    .header__nav {
      gap: 0;
    }
    .header__link {
      padding: 0.35rem 0.5rem;
      font-size: 0.65rem;
    }
    .header__name-dim { display: none; }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 60);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
