---
const links = [
  { href: '#making', label: 'Making' },
  { href: '#now', label: 'Now' },
  { href: '#journey', label: 'Journey' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="header" id="site-header">
  <div class="header__inner wrap">
    <a href="/" class="header__brand" aria-label="Home">
      <img src={`${import.meta.env.BASE_URL}mayi-mark.svg`} alt="" width="32" height="32" aria-hidden="true" />
      <span class="header__name">Mayibongwe<span class="header__name-dim"> Sibanda</span></span>
    </a>

    <nav class="header__nav" id="site-nav" aria-label="Primary">
      {links.map(({ href, label }) => (
        <a href={href} class="header__link">{label}</a>
      ))}
      <a href="https://www.linkedin.com/in/mayibongwe" rel="noopener noreferrer" target="_blank" class="header__link header__link--accent">
        LinkedIn
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>

    <div class="header__controls">
      <!-- Light / dark toggle -->
      <button class="header__mode-btn" id="mode-toggle" aria-label="Toggle light/dark mode" type="button">
        <!-- Sun (shown in dark mode) -->
        <svg class="mode-icon mode-icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg class="mode-icon mode-icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Hamburger (mobile only) -->
      <button class="header__burger" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="site-nav" type="button">
        <span class="burger__bar"></span>
        <span class="burger__bar"></span>
        <span class="burger__bar"></span>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding-block: 1rem;
    background: transparent;
    transition: background var(--transition), box-shadow var(--transition), padding var(--transition);
  }

  .header.is-scrolled {
    background: var(--header-bg-scrolled);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    box-shadow: 0 1px 0 var(--border);
    padding-block: 0.65rem;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--text);
    transition: opacity var(--transition);
    flex-shrink: 0;
  }
  .header__brand:hover { opacity: 0.8; color: var(--text); }

  .header__name {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .header__name-dim {
    color: var(--text-muted);
    font-weight: 400;
  }

  /* Nav */
  .header__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    justify-content: flex-end;
  }

  .header__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.75rem;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-decoration: none;
    border-radius: 100px;
    transition: color var(--transition), background var(--transition);
    white-space: nowrap;
  }
  .header__link:hover {
    color: var(--text);
    background: rgba(128, 128, 128, 0.08);
  }
  .header__link--accent { color: var(--accent); }
  .header__link--accent:hover {
    color: var(--accent-light);
    background: var(--accent-dim);
  }

  /* Controls (mode toggle + burger) */
  .header__controls {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  /* Mode toggle button */
  .header__mode-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--border-strong);
    border-radius: 50%;
    color: var(--text-muted);
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }
  .header__mode-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }

  /* Show correct icon per mode */
  :root:not([data-mode="light"]) .mode-icon--moon { display: none; }
  [data-mode="light"] .mode-icon--sun { display: none; }

  /* Hamburger */
  .header__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    transition: border-color var(--transition);
  }
  .header__burger:hover { border-color: var(--accent); }

  .burger__bar {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--text-muted);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease, background var(--transition);
  }
  .header__burger:hover .burger__bar { background: var(--accent); }

  /* Open state — animate to X */
  .header__burger[aria-expanded="true"] .burger__bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .header__burger[aria-expanded="true"] .burger__bar:nth-child(2) {
    opacity: 0;
  }
  .header__burger[aria-expanded="true"] .burger__bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Mobile ── */
  @media (max-width: 720px) {
    .header__burger { display: flex; }
    .header__name-dim { display: none; }

    .header__nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.75rem 1rem 1rem;
      background: var(--header-bg-scrolled);
      backdrop-filter: blur(20px) saturate(1.2);
      -webkit-backdrop-filter: blur(20px) saturate(1.2);
      border-bottom: 1px solid var(--border);
      /* Hidden by default */
      opacity: 0;
      pointer-events: none;
      transform: translateY(-8px);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .header__nav.is-open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .header__link {
      padding: 0.75rem 0.5rem;
      border-radius: 8px;
      justify-content: space-between;
    }
  }
</style>

<script>
  // Scroll shrink
  const header = document.getElementById('site-header');
  if (header) {
    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 60);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Mobile nav toggle
  const burger = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  if (burger && nav) {
    burger.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!open));
      burger.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
      nav.classList.toggle('is-open', !open);
    });
    // Close on link click
    nav.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        burger.setAttribute('aria-expanded', 'false');
        burger.setAttribute('aria-label', 'Open menu');
        nav.classList.remove('is-open');
      });
    });
  }

  // Light / dark mode toggle
  const modeBtn = document.getElementById('mode-toggle');
  const MODE_KEY = 'portfolio-mode';

  function applyMode(mode: string) {
    if (mode === 'light') {
      document.documentElement.dataset.mode = 'light';
    } else {
      delete document.documentElement.dataset.mode;
    }
    localStorage.setItem(MODE_KEY, mode);
  }

  if (modeBtn) {
    modeBtn.addEventListener('click', () => {
      const current = document.documentElement.dataset.mode === 'light' ? 'light' : 'dark';
      applyMode(current === 'light' ? 'dark' : 'light');
    });
  }
</script>
