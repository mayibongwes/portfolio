---

---

<section class="hero" aria-labelledby="hero-heading">
  <div class="glow hero__glow"></div>
  <div class="wrap hero__wrap">

    <div class="hero__kicker reveal">
      <span class="hero__tag">Johannesburg</span>
      <span class="hero__sep" aria-hidden="true">·</span>
      <span class="hero__tag">Software engineering</span>
      <span class="hero__sep" aria-hidden="true">·</span>
      <span class="hero__tag">Building on the side</span>
    </div>

    <h1 id="hero-heading" class="hero__title reveal reveal-delay-1">
      Engineer.<br/>
      Builder.<br/>
      <em>Curious.</em>
    </h1>

    <div class="hero__body reveal reveal-delay-2">
      <p>
        Software Engineer — Lead, working on medical administration systems for a healthcare department.
        Outside work, I'm building apps and creating with friends —
        because the drive to make things doesn't clock out.
      </p>
    </div>

    <div class="hero__actions reveal reveal-delay-3">
      <a class="btn btn--primary" href="#making">What I'm making</a>
      <a class="btn btn--outline" href="#journey">The road here</a>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <div class="hero__scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    padding-bottom: var(--space-lg);
    overflow: hidden;
  }

  .hero__glow {
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 600px;
  }

  .hero__wrap {
    position: relative;
    z-index: 1;
  }

  .hero__kicker {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-md);
  }

  .hero__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .hero__sep {
    color: var(--accent);
    font-size: var(--text-xs);
  }

  .hero__title {
    font-size: var(--text-5xl);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
  }

  .hero__title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero__body {
    max-width: 32rem;
    margin-bottom: var(--space-md);
  }

  .hero__body p {
    font-size: var(--text-lg);
    line-height: 1.75;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__scroll {
    position: absolute;
    bottom: -3rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .hero__scroll-line {
    width: 1px;
    height: 4rem;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 640px) {
    .hero { padding-top: 5rem; min-height: 90vh; }
    .hero__title br { display: none; }
    .hero__scroll { display: none; }
  }
</style>
