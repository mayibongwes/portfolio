---
const principles = [
  {
    number: '01',
    title: 'Intent before implementation',
    body: 'I push for written clarity on who we serve, what "done" means, and what we\'re explicitly not building — before anyone touches code. In healthcare, ambiguity costs more than time.',
  },
  {
    number: '02',
    title: 'Boring architecture, reliable systems',
    body: 'I prefer proven patterns, sensible automation, and code reviews that teach. Reliability in medical administration means the next release should be cheaper and safer than the last.',
  },
  {
    number: '03',
    title: 'Bridging clinical and engineering',
    body: 'I translate between business stakeholders and the development team without hiding uncertainty. In regulated healthcare contexts, honest communication matters as much as velocity.',
  },
];
---

<section id="approach" class="section approach">
  <div class="wrap">
    <div class="approach__header reveal">
      <p class="section-label">Approach</p>
      <h2>How I lead</h2>
    </div>

    <div class="approach__grid">
      {principles.map((p, i) => (
        <article class={`approach__item reveal reveal-delay-${i + 1}`}>
          <div class="approach__number-wrap">
            <span class="approach__number">{p.number}</span>
            <span class="approach__rule"></span>
          </div>
          <h3 class="approach__title">{p.title}</h3>
          <p class="approach__body">{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .approach {
    background: var(--surface);
    border-block: 1px solid var(--border);
  }

  .approach__header {
    margin-bottom: var(--space-lg);
  }

  .approach__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .approach__item {
    background: var(--bg);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .approach__number-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .approach__number {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    color: var(--accent);
    line-height: 1;
    flex-shrink: 0;
  }

  .approach__rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--accent), transparent);
    opacity: 0.3;
  }

  .approach__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--text);
    font-style: italic;
    line-height: 1.35;
  }

  .approach__body {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .approach__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
