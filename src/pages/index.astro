---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Making from '../components/Making.astro';
import Now from '../components/Now.astro';
import Journey from '../components/Journey.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const title = 'Mayibongwe Sibanda — Engineer. Builder. Curious.';
const description =
  'Software Engineer — Lead at a healthcare department, building apps on the side and always making things. Based in Johannesburg.';
---

<BaseLayout title={title} description={description} path="/">
  <Header />
  <main>
    <Hero />
    <hr class="divider" />
    <Making />
    <Now />
    <hr class="divider" />
    <Journey />
    <hr class="divider" />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
